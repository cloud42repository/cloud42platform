{
  "name": "api-connector-backend",
  "version": "1.0.0",
  "description": "NestJS backend exposing all API connector clients",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:mock": "ts-node -r dotenv/config -r tsconfig-paths/register src/main.ts dotenv_config_path=.env.mock",
    "start:debug": "ts-node --inspect -r tsconfig-paths/register src/main.ts",
    "start:debug:mock": "node --inspect -r ts-node/register -r dotenv/config -r tsconfig-paths/register src/main.ts dotenv_config_path=.env.mock",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.7.2",
    "axios-mock-adapter": "^1.22.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "google-auth-library": "^10.6.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  }
}
