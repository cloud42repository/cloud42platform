{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Backend (Mock)",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/backend/dist/**/*.js"],
      "resolveSourceMapLocations": ["${workspaceFolder}/backend/**", "!**/node_modules/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Backend (Mock Debug)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start:mock"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Angular (Chrome)",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:/*": "${workspaceFolder}/frontend/*",
        "/./*": "${workspaceFolder}/frontend/*",
        "/src/*": "${workspaceFolder}/frontend/src/*"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full Stack (Mock + Chrome)",
      "configurations": ["Launch Backend (Mock Debug)", "Launch Angular (Chrome)"]
    }
  ]
}
